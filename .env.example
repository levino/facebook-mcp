# Facebook App credentials (https://developers.facebook.com/apps/1290277286624394/)
FACEBOOK_APP_ID=1290277286624394
FACEBOOK_APP_SECRET=

# Graph API version (default v22.0)
FACEBOOK_GRAPH_VERSION=v22.0

# OAuth scope requested from Facebook during login
FACEBOOK_OAUTH_SCOPE=pages_manage_posts,pages_read_engagement,pages_show_list

# Bunny Database (libSQL). Generate under Database -> Access -> Generate Tokens.
BUNNY_DATABASE_URL=
BUNNY_DATABASE_AUTH_TOKEN=

# Optional token lifetimes (seconds). Sensible defaults are used if unset.
# ACCESS_TOKEN_TTL=3600
# REFRESH_TOKEN_TTL=2592000
# AUTH_CODE_TTL=300
# LOGIN_TTL=600
# SESSION_TTL=604800

# Note: there is no MCP_AUTH_TOKEN. MCP clients authenticate via the built-in
# OAuth flow (Login with Facebook). The Facebook OAuth redirect URI is always
# https://<your-host>/oauth/callback and is derived automatically — just make
# sure it is whitelisted in the Facebook app settings.
