# Facebook App credentials (https://developers.facebook.com/apps/1290277286624394/)
FACEBOOK_APP_ID=1290277286624394
FACEBOOK_APP_SECRET=

# Graph API version (default v22.0)
FACEBOOK_GRAPH_VERSION=v22.0

# OAuth scope requested during /oauth/start
FACEBOOK_OAUTH_SCOPE=pages_manage_posts,pages_read_engagement,pages_show_list

# Public URL of the OAuth callback. Must exactly match the redirect_uri used in
# /oauth/start and be whitelisted in the Facebook app settings.
# If unset it is derived from the incoming request origin + /oauth/callback.
OAUTH_REDIRECT_URI=

# Bearer token required on the MCP endpoint. If unset, the endpoint is open
# (only acceptable for local development).
MCP_AUTH_TOKEN=

# Bunny Database (libSQL). Generate under Database -> Access -> Generate Tokens.
BUNNY_DATABASE_URL=
BUNNY_DATABASE_AUTH_TOKEN=
